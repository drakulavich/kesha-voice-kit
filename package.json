{
  "name": "@drakulavich/kesha-voice-kit",
  "version": "1.1.2",
  "description": "Open-source voice toolkit for Apple Silicon. Speech-to-text, language detection. 25 languages.",
  "type": "module",
  "bin": {
    "kesha": "bin/kesha.js",
    "parakeet": "bin/kesha.js"
  },
  "exports": {
    ".": "./src/cli.ts",
    "./core": "./src/lib.ts"
  },
  "files": [
    "bin/",
    "src/",
    "package.json",
    "tsconfig.json",
    "openclaw.plugin.json",
    "openclaw-plugin.cjs",
    "SKILL.md",
    "scripts/postinstall.cjs",
    "LICENSE",
    "README.md"
  ],
  "openclaw": {
    "extensions": [
      "./openclaw-plugin.cjs"
    ]
  },
  "keshaEngine": {
    "version": "1.1.2"
  },
  "scripts": {
    "test": "bun test",
    "test:unit": "bun test tests/unit/",
    "test:integration": "bun test tests/integration/",
    "postinstall": "node scripts/postinstall.cjs"
  },
  "keywords": [
    "asr",
    "speech-to-text",
    "transcription",
    "voice",
    "kesha",
    "multilingual",
    "apple-silicon",
    "coreml",
    "bun",
    "cli"
  ],
  "author": "drakulavich",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drakulavich/kesha-voice-kit.git"
  },
  "homepage": "https://github.com/drakulavich/kesha-voice-kit#readme",
  "bugs": {
    "url": "https://github.com/drakulavich/kesha-voice-kit/issues"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "fast-xml-parser": "^5.5.10",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "citty": "^0.2.2",
    "fastest-levenshtein": "^1.0.16",
    "picocolors": "^1.1.1",
    "tinyld": "^1.3.4"
  }
}
