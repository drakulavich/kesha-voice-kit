{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git add *)",
      "Bash(git checkout -b *)",
      "Bash(git commit *)",
      "Bash(git stash*)",
      "Bash(git fetch*)",
      "Bash(git rebase*)",
      "Bash(gh pr *)",
      "Bash(gh run *)",
      "Bash(gh api *)",
      "Bash(gh issue *)",
      "Bash(gh release *)",
      "Bash(gh workflow *)",
      "Bash(openclaw doctor*)",
      "Bash(openclaw config get *)",
      "Bash(openclaw gateway status)",
      "Bash(openclaw cron runs*)",
      "Bash(openclaw sessions *)",
      "Bash(openclaw models*)",
      "Bash(openclaw approvals*)",
      "Bash(bun test*)",
      "Bash(bun run test*)",
      "Bash(bun install)",
      "Bash(bun link)",
      "Bash(bunx tsc*)",
      "Bash(clawhub inspect *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(grep *)",
      "Bash(make test)",
      "Bash(make lint)",
      "Bash(make unit)",
      "Bash(make integration)",
      "Bash(make smoke-test)",
      "Bash(make release)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/auto-fmt-rust.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/guard-sha-bump.sh"
          }
        ]
      }
    ]
  }
}
